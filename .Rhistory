# Multinomial Regression Dataset: Transportation Mode Choice
# Theme: Urban planning study examining daily commuting choices
# Designed to meet specific textbook requirements:
# - Categorical nominal Y with 4+ levels
# - 1 significant continuous X
# - 1 non-significant continuous X
# - 1 significant binary X
# - 1 non-significant binary X
# - 1 significant 4-level categorical nominal X
set.seed(42)
n <- 1000
# Generate the 5 required predictor variables
# 1. SIGNIFICANT CONTINUOUS X: Commute distance (should strongly affect transport choice)
commute_distance <- round(runif(n, 0.5, 25), 1)  # Distance in kilometers
# 2. NON-SIGNIFICANT CONTINUOUS X: Age (should have minimal effect on transport choice)
age <- round(runif(n, 18, 65), 0)  # Age in years
# 3. SIGNIFICANT BINARY X: Has car available (should strongly affect transport choice)
has_car_available <- sample(0:1, n, replace = TRUE, prob = c(0.3, 0.7))  # 0=No, 1=Yes
# 4. NON-SIGNIFICANT BINARY X: Weekend commuter (should have minimal effect)
weekend_commuter <- sample(0:1, n, replace = TRUE, prob = c(0.85, 0.15))  # 0=No, 1=Yes
# 5. SIGNIFICANT 4-LEVEL CATEGORICAL NOMINAL X: Income bracket (should affect transport choice)
income_bracket <- sample(c("Low", "Medium", "High", "Very_High"), n, replace = TRUE,
prob = c(0.25, 0.35, 0.25, 0.15))
# Create dummy variables for income bracket (for modeling)
income_medium <- ifelse(income_bracket == "Medium", 1, 0)
income_high <- ifelse(income_bracket == "High", 1, 0)
income_very_high <- ifelse(income_bracket == "Very_High", 1, 0)
# Low is reference category
# Create linear predictors for each transportation mode
# Car as reference category (will be omitted from model)
# PUBLIC TRANSIT - affected by: distance (+), no car (-), higher income (+)
public_transit_logit <- -2.0 +
0.12 * commute_distance +           # SIGNIFICANT: longer distance favors transit
0.001 * age +                       # NON-SIGNIFICANT: age has minimal effect
-1.5 * has_car_available +          # SIGNIFICANT: having car reduces transit use
0.1 * weekend_commuter +            # NON-SIGNIFICANT: weekend pattern irrelevant
0.8 * income_medium +               # SIGNIFICANT: income affects transit choice
1.2 * income_high +
1.5 * income_very_high +
rnorm(n, 0, 0.4)
# BICYCLE - affected by: shorter distance (+), no car (+), medium income (+)
bicycle_logit <- -2.5 +
-0.18 * commute_distance +          # SIGNIFICANT: shorter distance favors cycling
-0.002 * age +                      # NON-SIGNIFICANT: age has minimal effect
0.8 * (1 - has_car_available) +     # SIGNIFICANT: no car increases cycling
-0.05 * weekend_commuter +          # NON-SIGNIFICANT: weekend pattern irrelevant
0.6 * income_medium +               # SIGNIFICANT: income affects cycling choice
0.3 * income_high +
-0.4 * income_very_high +
rnorm(n, 0, 0.4)
# WALKING - affected by: very short distance (+), no car (+), lower income (+)
walking_logit <- -3.5 +
-0.25 * commute_distance +          # SIGNIFICANT: very short distance favors walking
0.003 * age +                       # NON-SIGNIFICANT: age has minimal effect
0.6 * (1 - has_car_available) +     # SIGNIFICANT: no car increases walking
0.08 * weekend_commuter +           # NON-SIGNIFICANT: weekend pattern irrelevant
-0.3 * income_medium +              # SIGNIFICANT: income affects walking choice
-0.8 * income_high +
-1.2 * income_very_high +
rnorm(n, 0, 0.4)
# Car logit is 0 (reference category)
car_logit <- rep(0, n)
# Combine all logits and apply softmax to get probabilities
logits <- cbind(car_logit, public_transit_logit, bicycle_logit, walking_logit)
probabilities <- exp(logits) / rowSums(exp(logits))
# Generate transport mode choices
transport_choices <- c("Car", "Public_Transit", "Bicycle", "Walking")
transport_mode <- character(n)
for(i in 1:n) {
transport_mode[i] <- sample(transport_choices, 1, prob = probabilities[i, ])
}
# Create the final dataset with exactly the required variable structure
multinomial_transport <- data.frame(
# OUTCOME VARIABLE (Categorical nominal Y with 4 levels)
transport_mode = factor(transport_mode, levels = transport_choices),
# THE 5 REQUIRED PREDICTOR VARIABLES:
# 1. Significant continuous X
commute_distance = commute_distance,
# 2. Non-significant continuous X
age = age,
# 3. Significant binary X
has_car_available = factor(has_car_available, levels = c(0, 1), labels = c("No", "Yes")),
# 4. Non-significant binary X
weekend_commuter = factor(weekend_commuter, levels = c(0, 1), labels = c("No", "Yes")),
# 5. Significant 4-level categorical nominal X
income_bracket = factor(income_bracket, levels = c("Low", "Medium", "High", "Very_High"))
)
# Display summary statistics
cat("=== MULTINOMIAL REGRESSION DATASET: TRANSPORTATION MODE CHOICE ===\n")
cat("Dataset dimensions:", nrow(multinomial_transport), "rows x", ncol(multinomial_transport), "columns\n\n")
cat("OUTCOME VARIABLE:\n")
cat("Transport Mode Distribution (4 categories):\n")
print(table(multinomial_transport$transport_mode))
cat("\n")
cat("PREDICTOR VARIABLES:\n")
cat("1. SIGNIFICANT CONTINUOUS X - Commute Distance:\n")
cat("   Range:", min(multinomial_transport$commute_distance), "-", max(multinomial_transport$commute_distance), "km\n")
cat("   Mean:", round(mean(multinomial_transport$commute_distance), 2), "km\n\n")
cat("2. NON-SIGNIFICANT CONTINUOUS X - Age:\n")
cat("   Range:", min(multinomial_transport$age), "-", max(multinomial_transport$age), "years\n")
cat("   Mean:", round(mean(multinomial_transport$age), 1), "years\n\n")
cat("3. SIGNIFICANT BINARY X - Has Car Available:\n")
print(table(multinomial_transport$has_car_available))
cat("\n")
cat("4. NON-SIGNIFICANT BINARY X - Weekend Commuter:\n")
print(table(multinomial_transport$weekend_commuter))
cat("\n")
cat("5. SIGNIFICANT 4-LEVEL CATEGORICAL NOMINAL X - Income Bracket:\n")
print(table(multinomial_transport$income_bracket))
cat("\n")
cat("=== SUMMARY STATISTICS ===\n")
print(summary(multinomial_transport))
cat("\n=== SAMPLE DATA (first 10 rows) ===\n")
print(head(multinomial_transport, 10))
cat("\n=== EXPECTED SIGNIFICANCE PATTERNS ===\n")
cat("When you run multinomial logistic regression:\n")
cat("- commute_distance should be SIGNIFICANT (strong effect on transport choice)\n")
cat("- age should be NON-SIGNIFICANT (minimal effect on transport choice)\n")
cat("- has_car_available should be SIGNIFICANT (strong effect on transport choice)\n")
cat("- weekend_commuter should be NON-SIGNIFICANT (minimal effect on transport choice)\n")
cat("- income_bracket should be SIGNIFICANT (strong effect on transport choice)\n")
# Save the dataset
write.csv(multinomial_transport, "multinomial_transport.csv", row.names = FALSE)
